# ============================================
# GETYOURSHARE - PRODUCTION ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to git!

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=production
PORT=8000

# ============================================
# JWT & SECURITY (CRITICAL - MUST SET)
# ============================================
# Generate secure random strings for these:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=CHANGE_ME_32_CHARS_MINIMUM
REFRESH_TOKEN_SECRET=CHANGE_ME_32_CHARS_DIFFERENT

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# SUPABASE DATABASE
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database connection (alternative)
DATABASE_URL=postgresql://user:password@host:port/database

# ============================================
# FRONTEND CORS
# ============================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# EMAIL SERVICE (Resend)
# ============================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com

# ============================================
# STRIPE PAYMENTS
# ============================================
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# ============================================
# AI SERVICES (Optional)
# ============================================
# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# ============================================
# REDIS (Optional - for rate limiting)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# CELERY (Optional - for background tasks)
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ============================================
# MONITORING & LOGGING (Optional)
# ============================================
SENTRY_DSN=https://xxxxxxxxxxxxx@sentry.io/xxxxx
LOG_LEVEL=INFO

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ============================================
# WEBHOOK URLs (Optional)
# ============================================
WEBHOOK_BASE_URL=https://your-api-domain.com
